+package com.inventorymanager.backend.web;
+
+import static org.junit.jupiter.api.Assertions.assertThrows;
+import static org.junit.jupiter.api.Assertions.assertEquals;
+
+import com.inventorymanager.backend.common.ApiException;
+import org.junit.jupiter.api.Test;
+import org.springframework.http.HttpStatus;
+
+public class UserControllerHostileTest {
+
+    @Test
+    public void testCreateUserWithNullPasswordThrowsException() {
+        // Dependencies can be null since it should fail fast on validation
+        UserController controller = new UserController(null, null, null, null, null, null);
+        CrudRequest.UserUpsert req = new CrudRequest.UserUpsert("user", null, null, null);
+        
+        ApiException ex = assertThrows(ApiException.class, () -> controller.create(req));
+        assertEquals(HttpStatus.BAD_REQUEST, ex.getStatus(), "Expected BAD_REQUEST status");
+        assertEquals("Password is required for new users", ex.getMessage());
+    }
+
+    @Test
+    public void testCreateUserWithBlankPasswordThrowsException() {
+        UserController controller = new UserController(null, null, null, null, null, null);
+        CrudRequest.UserUpsert req = new CrudRequest.UserUpsert("user", "   ", null, null);
+        
+        ApiException ex = assertThrows(ApiException.class, () -> controller.create(req));
+        assertEquals(HttpStatus.BAD_REQUEST, ex.getStatus(), "Expected BAD_REQUEST status");
+        assertEquals("Password is required for new users", ex.getMessage());
+    }
+}
