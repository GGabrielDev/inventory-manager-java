#!/bin/bash

set -euo pipefail

ROOT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || true)
COMMIT_SHA=$(git rev-parse --verify HEAD 2>/dev/null || true)

if [ -z "${ROOT_DIR}" ] || [ -z "${COMMIT_SHA}" ]; then
  exit 0
fi

RUNNER="${ROOT_DIR}/tools/hooks/run-passive-guards.sh"
if [ ! -x "${RUNNER}" ]; then
  exit 0
fi

mkdir -p "${ROOT_DIR}/.gemini/local-guards"
nohup "${RUNNER}" "${COMMIT_SHA}" >/dev/null 2>&1 &

echo "🛡️ Passive Gemini guards started for commit ${COMMIT_SHA:0:8} (non-blocking)."
echo "📄 Report will appear under .gemini/local-guards/"
