#!/bin/bash

# Test Adversary Pre-Commit Hook
# Purpose: Ensure tests are rigorous and adversarial for new code.

export PATH=$PATH:/usr/local/bin:/usr/bin:/bin

echo "🛡️ Running Test Adversary Validation..."

# 1. Get staged changes
STAGED_DIFF=$(git diff --cached)

if [ -z "$STAGED_DIFF" ]; then
    echo "No staged changes to audit."
    exit 0
fi

# 2. Run Gemini in headless mode with Test Adversary Rules
# We pass the rules file and the diff.
# We expect the AI to output PASS or FAIL.

echo "DEBUG: Running gemini..."
gemini --prompt "Review the following staged changes against the Test Adversary Rules. 
Generate and run hostile tests if needed. 
RULES: $(cat .agents/rules/test-adversary-rules.md)
DIFF:
$STAGED_DIFF" --yolo > .gemini_hook_result 2>&1

RESULT=$(cat .gemini_hook_result)
echo "$RESULT"

if [[ "$RESULT" == *"FAIL"* ]]; then
    echo "❌ Test Adversary Rejected Commit:"
    echo "$RESULT"
    exit 1
elif [[ "$RESULT" == *"PASS"* ]]; then
    echo "✅ Test Adversary Passed."
    exit 0
else
    echo "⚠️ Test Adversary output ambiguous. Please review manually."
    echo "$RESULT"
    exit 1
fi
