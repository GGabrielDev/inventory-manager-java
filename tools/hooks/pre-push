#!/bin/bash

set -euo pipefail

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "${ROOT_DIR}"

echo "🔎 Running pre-push Java checks..."

echo "• Compile all modules"
mvn -q -DskipTests clean compile

echo "• Run backend unit/integration tests"
mvn -q -pl backend test

echo "• Run local recursive Copilot adversary/auditor checks"
"${ROOT_DIR}/tools/hooks/run-copilot-recursive-guards.sh"

echo "✅ Pre-push checks passed."
