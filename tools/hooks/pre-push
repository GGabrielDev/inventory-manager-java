#!/bin/bash

set -euo pipefail

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "${ROOT_DIR}"

REFS_FILE=$(mktemp)
cat > "${REFS_FILE}"
trap 'rm -f "${REFS_FILE}"' EXIT

echo "🔎 Running pre-push Java checks..."

echo "• Compile all modules"
mvn -q -DskipTests clean compile

echo "• Run backend unit/integration tests"
mvn -q -pl backend test

echo "• Run local headless Copilot adversary/auditor checks"
"${ROOT_DIR}/tools/hooks/run-copilot-prepush-guards.sh" "${REFS_FILE}"

echo "✅ Pre-push checks passed."
